                    <TextBlock Grid.Row="0" Grid.Column="2" Text="55  54  53  52" Style="{StaticResource MaterialDesignOverlineTextBlock}"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="1  0  1  0" Style="{StaticResource MaterialDesignBody1TextBlock}"/>

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="51  50  49  48" Style="{StaticResource MaterialDesignOverlineTextBlock}"/>
