                    <TextBlock Grid.Row="2" Grid.Column="0" Text="63  62  61  60" Style="{StaticResource MaterialDesignOverlineTextBlock}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="1  0  1  0" Style="{StaticResource MaterialDesignBody1TextBlock}"/>

                    <TextBlock Grid.Row="2" Grid.Column="1" Text="63  62  61  60" Style="{StaticResource MaterialDesignOverlineTextBlock}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="1  0  1  0" Style="{StaticResource MaterialDesignBody1TextBlock}"/>

                    <TextBlock Grid.Row="2" Grid.Column="2" Text="63  62  61  60" Style="{StaticResource MaterialDesignOverlineTextBlock}"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="1  0  1  0" Style="{StaticResource MaterialDesignBody1TextBlock}"/>

                    <TextBlock Grid.Row="2" Grid.Column="3" Text="63  62  61  60" Style="{StaticResource MaterialDesignOverlineTextBlock}"/>
                    <TextBlock Grid.Row="3" Grid.Column="3" Text="1  0  1  0" Style="{StaticResource MaterialDesignBody1TextBlock}"/>
</Grid>

